PORT=4000
DB_PATH=./data/imss.db

# Genera valores seguros con:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=cambia_este_secreto_jwt
JWT_REFRESH_SECRET=cambia_este_secreto_refresh
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# URL del frontend (para CORS y enlaces en emails)
CLIENT_ORIGIN=http://localhost:5173

# SMTP — opcional, si no se configura el enlace de reset se imprime en consola
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=tu_email@gmail.com
SMTP_PASS=tu_contrasena_o_app_password
SMTP_FROM=no-reply@imss.gob.mx
